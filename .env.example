# Browser-safe values
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=replace-with-local-anon-key

# Supabase Edge Function secrets (never expose the service role in VITE_* variables)
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=replace-with-local-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-local-service-role-key
OPENROUTER_API_KEY=replace-with-openrouter-key
OPENROUTER_MODEL=google/gemini-2.5-flash
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
AI_REQUEST_TIMEOUT_MS=30000
AI_MAX_RETRIES=2
AI_RATE_LIMIT_WINDOW=3600
AI_RATE_LIMIT_MAX_REQUESTS=20
